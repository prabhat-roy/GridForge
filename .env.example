# ============================================================
# Project-wide local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (primary transactional store) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# ----- TimescaleDB (AMI 15-min meter reads) -----
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_USER=app
TIMESCALE_PASSWORD=app
TIMESCALE_DB=ami

# ----- InfluxDB (high-freq grid telemetry / PMU) -----
INFLUX_URL=http://localhost:8086
INFLUX_ORG=gridforge
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=local-dev-token

# ----- Cassandra (long-term meter archive) -----
CASSANDRA_HOSTS=localhost:9042
CASSANDRA_KEYSPACE=ami_archive

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- ClickHouse (revenue / loss analytics) -----
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=gridforge

# ----- Kafka (IT event bus) -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- MQTT (AMI ingest) -----
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=ami
MQTT_PASSWORD=ami

# ----- AMQP (SCADA event bus) -----
AMQP_URL=amqp://guest:guest@localhost:5672/

# ----- NATS JetStream -----
NATS_URL=nats://localhost:4222

# ----- Object storage (MinIO) -----
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gridforge

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/gridforge
OIDC_CLIENT_ID=gridforge
OIDC_CLIENT_SECRET=change-me

# ----- Vault -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- IT/OT separation (set on IT-side services) -----
OT_GATEWAY_URL=https://scada-gateway.ot.svc.cluster.local
OT_BREAK_GLASS_REQUIRED=true
